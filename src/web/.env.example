NEXT_PUBLIC_APP_URL=http://localhost:8000
NEXT_PUBLIC_TERMINAL_URL=http://localhost:8001

# Google OAuth (for Gmail email integration)
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Add http://localhost:8000/api/email/oauth/callback as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/email/oauth/callback

# AES-256-GCM key for encrypting Credential/JobBoard/EmailAccount secret columns at rest.
# Generate with `bun run generate-key`. Never commit this - losing it makes stored secrets unrecoverable.
CREDENTIAL_ENCRYPTION_KEY=
