{
  "name": "@careerpilot/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 8000",
    "build": "next build",
    "start": "next start -p 8000",
    "lint": "eslint",
    "typegen": "next typegen",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "db:generate": "prisma generate --schema ./prisma/schema",
    "db:migrate": "prisma migrate dev --schema ./prisma/schema --create-only",
    "db:migrate:apply": "prisma migrate deploy --schema ./prisma/schema",
    "db:studio": "prisma studio --schema ./prisma/schema",
    "db:seed": "bun run prisma/seed/default-boards.ts",
    "db:reset": "prisma migrate reset --schema ./prisma/schema --skip-seed",
    "generate-key": "bun run scripts/generate-key.ts",
    "migrate-secrets": "bun run scripts/migrate-secrets.ts"
  },
  "dependencies": {
    "@2captcha/captcha-solver": "^1.3.6",
    "@emotion/cache": "^11.13.5",
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@libsql/client": "^0.17.3",
    "@mui/icons-material": "^9.1.0",
    "@mui/material": "^9.1.0",
    "@mui/material-nextjs": "^9.1.0",
    "@mui/x-charts": "^9.5.0",
    "@mui/x-data-grid": "^9.5.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-pdf/renderer": "^4.5.1",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-query": "^5.100.0",
    "@tanstack/react-query-devtools": "^5.100.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "google-auth-library": "^10.7.0",
    "googleapis": "^173.0.0",
    "libphonenumber-js": "^1.13.2",
    "next": "^16.2.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.5.0",
    "eslint-config-next": "^16.2.5",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  }
}
