model Contact {
  id        Int     @id @default(autoincrement())
  profileId Int
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name            String
  title           String?
  company         String?
  linkedinUrl     String?
  email           String?
  emailSource     String? // "guessed" | "verified" | "provided"
  emailConfidence Float?

  linkedinConnection String  @default("none") // none | pending | connected
  discoverySource    String? // "google" | "company-site" | "web" | "linkedin" | "manual"
  matchConfidence    Float? // confidence we found the right person

  relatedAppId  Int? // job-tied scope
  relatedApp    Application? @relation(fields: [relatedAppId], references: [id], onDelete: SetNull)
  relatedJobUrl String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages OutreachMessage[]

  @@index([profileId])
  @@index([profileId, company])
}

model OutreachMessage {
  id        Int     @id @default(autoincrement())
  profileId Int
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  contactId Int
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [campaignId], onDelete: SetNull)

  channel      String // "email" | "linkedin"
  linkedinKind String? // "inmail" | "connect_note" | "dm"
  subject      String?
  body         String  @default("")

  status     String  @default("draft") // draft | approved | sent | replied | bounced | failed | skipped
  failReason String?
  providerId String? // Gmail message id (sent)
  threadId   String? // Gmail thread id — used for reply matching
  sentAt     DateTime?
  repliedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([profileId])
  @@index([campaignId])
  @@index([contactId])
  @@index([threadId])
  @@index([status])
}
